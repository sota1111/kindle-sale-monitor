# ===================================
# アプリケーション設定
# ===================================

# Discord Webhook URL（省略可。未設定時は通知をスキップして動作確認できる）
# Cloud Run本番環境ではSecret Manager管理 (secret name: kindle-monitor-discord-webhook-url)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# DB接続URL（ローカル実行時。Cloud Runでは通常不要）
DATABASE_URL=sqlite:///./kindle_monitor.db

# 定期監視間隔（時間単位）
CHECK_INTERVAL_HOURS=12

# sale-bonリクエスト間隔（秒）
REQUEST_INTERVAL_SECONDS=2

# リクエストタイムアウト（秒）
REQUEST_TIMEOUT_SECONDS=30

# 最大リトライ回数
MAX_RETRIES=3

# ログレベル: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# サーバーポート（Cloud Runは自動設定。ローカルのデフォルト: 8000）
PORT=8000

# ===================================
# GCP / Firestore設定（Cloud Run使用時）
# ===================================

# GCPプロジェクトID（Firestoreを使う場合は必須。未設定時はSQLiteで動作）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# FirestoreデータベースID（省略可、デフォルト: (default)）
FIRESTORE_DATABASE_ID=(default)

# ローカル実行用欲しい本リストファイルパス（省略可、デフォルト: wishlist.json）
LOCAL_WISHLIST_FILE=wishlist.json

# ===================================
# Firebase Authentication設定（案1: サーバサイドREST認証）
# ===================================
# Firebase Web API key。サーバが Identity Toolkit REST
# (accounts:signInWithPassword) でメール/パスワードを照合するために使用する。
# ブラウザはFirebaseと直接通信しない。Cloud Run本番ではSecret Manager管理推奨。
FIREBASE_API_KEY=your-firebase-api-key

# 許可するメールアドレス（カンマ区切り）
# Cloud Run本番環境ではSecret Manager管理推奨
ALLOWED_USER_EMAILS=your-email@example.com

# セッションcookie署名用シークレット（32文字以上推奨）
# Cloud Run本番環境ではSecret Manager管理
AUTH_SECRET=your-random-secret-key-here
