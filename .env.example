# ===================================
# アプリケーション設定
# ===================================

# Discord Webhook URL（必須）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# DB接続URL（ローカル実行時。Cloud Runでは通常不要）
DATABASE_URL=sqlite:///./kindle_monitor.db

# 定期監視間隔（時間単位）
CHECK_INTERVAL_HOURS=12

# sale-bonリクエスト間隔（秒）
REQUEST_INTERVAL_SECONDS=2

# リクエストタイムアウト（秒）
REQUEST_TIMEOUT_SECONDS=30

# 最大リトライ回数
MAX_RETRIES=3

# ログレベル: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# サーバーポート（Cloud Runは自動設定。ローカルのデフォルト: 8000）
PORT=8000

# ===================================
# GCP / Firestore設定（Cloud Run使用時）
# ===================================

# GCPプロジェクトID（Firestoreを使う場合は必須。未設定時はSQLiteで動作）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# FirestoreデータベースID（省略可、デフォルト: (default)）
FIRESTORE_DATABASE_ID=(default)

# ローカル実行用欲しい本リストファイルパス（省略可、デフォルト: wishlist.json）
LOCAL_WISHLIST_FILE=wishlist.json
