# ===================================
# アプリケーション設定
# ===================================

# Discord Webhook URL（省略可。未設定時は通知をスキップして動作確認できる）
# Cloud Run本番環境ではSecret Manager管理 (secret name: kindle-monitor-discord-webhook-url)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# DB接続URL（ローカル実行時。Cloud Runでは通常不要）
DATABASE_URL=sqlite:///./kindle_monitor.db

# 定期監視間隔（時間単位）
CHECK_INTERVAL_HOURS=12

# sale-bonリクエスト間隔（秒）
REQUEST_INTERVAL_SECONDS=2

# リクエストタイムアウト（秒）
REQUEST_TIMEOUT_SECONDS=30

# 最大リトライ回数
MAX_RETRIES=3

# ログレベル: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# サーバーポート（Cloud Runは自動設定。ローカルのデフォルト: 8000）
PORT=8000

# ===================================
# GCP / Firestore設定（Cloud Run使用時）
# ===================================

# GCPプロジェクトID（Firestoreを使う場合は必須。未設定時はSQLiteで動作）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# FirestoreデータベースID（省略可、デフォルト: (default)）
FIRESTORE_DATABASE_ID=(default)

# ローカル実行用欲しい本リストファイルパス（省略可、デフォルト: wishlist.json）
LOCAL_WISHLIST_FILE=wishlist.json

# ===================================
# Amazon PA-API 5.0設定（実データ取得元）
# ===================================
# データ源の選択: auto | paapi | scrape | browser
#   auto   : PA-API認証情報が揃っていればPA-API、無ければsale-bonスクレイピング（デフォルト）
#   paapi  : 常にPA-APIを使用
#   scrape : 常にsale-bonスクレイピングを使用（サイト側ブロックにより現在は失敗する）
#   browser: ログイン済みローカルChromium(Playwright)で各 /dp/<asin> を巡回（ローカルPC専用）
DATA_SOURCE=auto

# ===================================
# ログイン済みローカルブラウザ収集（DATA_SOURCE=browser のときのみ使用）
# ===================================
# Playwright永続プロファイルの保存先。初回のみ BROWSER_HEADLESS=false で手動ログインし、
# 以後は保存されたCookieをheadlessで再利用する。Cloud Run等の本番では使用不可（ローカルPC専用）。
# 事前準備: uv sync && uv run playwright install chromium
# BROWSER_PROFILE_DIR=~/.kindle-monitor/browser-profile
# BROWSER_HEADLESS=true

# Amazonアソシエイト + PA-API 5.0 の認証情報。
# Cloud Run本番環境ではSecret Manager管理推奨。
# PAAPI_ACCESS_KEY=your-paapi-access-key
# PAAPI_SECRET_KEY=your-paapi-secret-key
# PAAPI_PARTNER_TAG=your-associate-tag-22

# マーケットプレイス / リージョン（日本: 既定値のままでよい）
PAAPI_MARKETPLACE=www.amazon.co.jp
PAAPI_HOST=webservices.amazon.co.jp
PAAPI_REGION=us-west-2

# ===================================
# Firebase Authentication設定（案1: サーバサイドREST認証）
# ===================================
# Firebase Web API key。サーバが Identity Toolkit REST
# (accounts:signInWithPassword) でメール/パスワードを照合するために使用する。
# ブラウザはFirebaseと直接通信しない。Cloud Run本番ではSecret Manager管理推奨。
# FIREBASE_WEB_API_KEY が優先され、未設定時は FIREBASE_API_KEY にフォールバックする（どちらか一方でログイン可）。
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_API_KEY=your-firebase-api-key

# 許可するメールアドレス（カンマ区切り）
# Cloud Run本番環境ではSecret Manager管理推奨
ALLOWED_USER_EMAILS=your-email@example.com

# セッションcookie署名用シークレット（32文字以上推奨）
# Cloud Run本番環境ではSecret Manager管理
AUTH_SECRET=your-random-secret-key-here
